{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/slack/backfill",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/slack/backfill",
      "schedule": "0 13 * * *"
    }
  ]
}
